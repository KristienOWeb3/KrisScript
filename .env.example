# --- SubScript (https://subscriptonarc.com) ---
# Dashboard -> Developers -> API keys. sk_test_ = sandbox, sk_live_ = production.
# Leave BLANK to run Kris's Script in DEV MODE (simulated checkout, no real API calls).
SUBSCRIPT_SECRET_KEY=

# Dashboard -> Developers -> Webhooks. Used to verify x-subscript-signature.
# In dev mode (no secret key) a built-in dev secret is used automatically.
SUBSCRIPT_WEBHOOK_SECRET=

# --- DeepSeek ---
# https://platform.deepseek.com -> API keys. Leave blank for demo-mode replies.
DEEPSEEK_API_KEY=

# --- App ---
# Public URL of this app. Must be HTTPS for SubScript success/cancel redirects
# (use an ngrok/cloudflared tunnel URL in dev if you want redirects + real webhooks).
APP_URL=http://localhost:3000

# Random string used to sign session cookies. Change in production.
AUTH_SECRET=change-me-to-a-long-random-string
